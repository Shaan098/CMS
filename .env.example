# MongoDB Configuration
# Option 1: Use MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cms_db?retryWrites=true&w=majority

# Option 2: Use Local MongoDB Container (Uncomment to use)
# MONGODB_URI=mongodb://admin:admin123@mongodb:27017/cms_db?authSource=admin

# JWT Secret Key (Change this to a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production
